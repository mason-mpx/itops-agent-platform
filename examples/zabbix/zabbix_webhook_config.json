{
  "name": "IT运维自动化平台",
  "type": "webhook",
  "parameters": [
    {
      "name": "trigger",
      "value": "{TRIGGER.NAME}"
    },
    {
      "name": "host",
      "value": "{HOST.NAME}"
    },
    {
      "name": "item",
      "value": "{ITEM.NAME}"
    },
    {
      "name": "value",
      "value": "{ITEM.LASTVALUE}"
    },
    {
      "name": "severity",
      "value": "{TRIGGER.SEVERITY}"
    }
  ],
  "url": "http://your-server:3001/api/webhooks/zabbix",
  "method": "POST",
  "content_type": "application/json",
  "timeout": "10s",
  "attempts": 3,
  "interval": "5s"
}
